# Environment Variables for Production
# Copy this file to .env and update with your actual values

# Allowed CORS origins (comma-separated)
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database path (optional - will use default if not set)
# For GoDaddy hosting, use absolute path like:
# DATABASE_PATH=/home/username/public_html/backend-api/app.db
# Or leave empty to use default location (backend-api/app.db)
DATABASE_PATH=

